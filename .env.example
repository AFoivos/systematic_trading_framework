# Copy this file to .env and populate only the accounts you use.
# The real .env is ignored by both Git and the Docker build context.
# Single-quote values containing spaces, #, or $ characters.

# MetaTrader 5 demo account
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Kraken Futures demo account
# The current Kraken adapter can load these credentials but order placement is
# not implemented yet.
KRAKEN_FUTURES_API_KEY=
KRAKEN_FUTURES_API_SECRET=

# Bybit Demo Trading account
BYBIT_EXECUTION_ENV=demo
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=
BYBIT_DEMO_REST_URL=https://api-demo.bybit.com
BYBIT_DEMO_PRIVATE_WS_URL=wss://stream-demo.bybit.com/v5/private
BYBIT_PUBLIC_WS_URL=wss://stream.bybit.com/v5/public/linear
RUN_BYBIT_DEMO_INTEGRATION_TESTS=0

# OANDA practice account
OANDA_ACCOUNT_ID=
OANDA_API_TOKEN=
